{{ rustfs_host }} {
        reverse_proxy http://{{ truenas_dns }}:19000
        tls {
                dns cloudflare {env.CLOUDFLARE_API_TOKEN}
                resolvers 1.1.1.1
        }
}

{{ rustfs_console_host }} {
        reverse_proxy http://{{ truenas_dns }}:19001
        tls {
                dns cloudflare {env.CLOUDFLARE_API_TOKEN}
                resolvers 1.1.1.1
        }
}
